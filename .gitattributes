# Default — let Git auto-detect line endings
* text=auto

# Force LF on shell scripts so they run cleanly on the Linux EBS VM
*.sh   text eol=lf
*.env  text eol=lf

# Markdown / SQL / source — auto-normalise
*.md   text
*.sql  text
*.pls  text
*.pks  text
*.pkb  text
*.xml  text
*.yml  text
*.yaml text

# Binary types — never modify
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.rtf  binary
*.wft  binary
