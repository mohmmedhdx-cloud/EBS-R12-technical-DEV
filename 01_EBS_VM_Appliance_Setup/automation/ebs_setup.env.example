# EBS VM post-import setup — config file.
# Copy this to ebs_setup.env and edit:
#   cp ebs_setup.env.example ebs_setup.env
#   chmod 600 ebs_setup.env
#
# Keep passwords ALPHANUMERIC ONLY (no $ " \ ' spaces). The expect scripts
# pass values through bash expansion.

# ============================================================
# Passwords — defaults match the project convention
# ============================================================

# Single password applied to SYSADMIN, all demo users, and DB base schemas.
NEW_PASSWORD='password'

# DB-tier accounts (SYS / SYSTEM / EBS_SYSTEM). Leave = NEW_PASSWORD or override.
SYS_PASSWORD="$NEW_PASSWORD"
SYSTEM_PASSWORD="$NEW_PASSWORD"
EBS_SYSTEM_PASSWORD="$NEW_PASSWORD"

# EBS_SYSTEM CURRENT password, as shipped in a fresh Vision VM.
# Used in phase 04 (changeDBpasswords.sh asks for it to authenticate
# before rotating).
CURRENT_EBS_SYSTEM_PASSWORD='manager'

# WebLogic admin account.
CURRENT_WLS_PASSWORD='welcome1'      # default shipped with the VM
NEW_WLS_PASSWORD='Welcome01'         # what we change it to

# APPS schema credentials.
# These are NOT changed by changeDBpasswords.sh — FNDCPASS ALLORACLE mode
# deliberately excludes APPS, APPLSYS, APPS_NE, and APPLSYSPUB.
# Default value = 'apps' (as shipped with the Vision VM).
# If you later rotate it manually with FNDCPASS ... APPLSYS <new>, update
# this value so phase 09 can keep driving the adstpall / adstrtal prompts.
APPS_USER='apps'
APPS_PASSWORD='apps'

# ============================================================
# Network — put your WINDOWS host IP here
# ============================================================
# The machine from which you'll open the EBS UI in a browser.
# Added to listener invited_nodes so it's allowed to connect on 1521.
HOST_IP='192.168.1.100'

# ============================================================
# Instance naming (defaults match the shipped Vision VM)
# ============================================================
CDB_NAME='EBSCDB'                    # container DB; Linux service is lowercase: ebscdb
PDB_NAME='EBSDB'                     # pluggable DB / apps service / SID
CONTEXT_NAME='EBSDB_apps'            # /u01/install/APPS/fs1/inst/apps/<CONTEXT_NAME>/

# ============================================================
# Env-sourcing files (rarely need changing)
# ============================================================
APPS_ENV='/u01/install/APPS/EBSapps.env'
DB_ENV='/u01/install/APPS/19.0.0/EBSCDB_apps.env'
