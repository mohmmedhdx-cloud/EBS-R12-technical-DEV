# ------------------------------------------------------------
# Secrets — never commit
# ------------------------------------------------------------
# The real env file holds passwords; only the .example template is public.
**/ebs_setup.env

# Any other .env files (keep only .env.example)
.env
**/.env

# Oracle wallets / keys
**/*.sso
**/cwallet.sso
**/ewallet.p12

# ------------------------------------------------------------
# Logs and runtime output
# ------------------------------------------------------------
*.log
**/logs/
**/log/ebs_setup_*/
**/L*.log
**/O*.out

# ------------------------------------------------------------
# Oracle-specific binary / export artifacts
# ------------------------------------------------------------
*.dmp
*.dmp.gz
*.dpdump
*.ldt.bak.*
*.wft.bak.*
*.rdf.bak.*
*.class
*.jar

# ------------------------------------------------------------
# Editor / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store

# ------------------------------------------------------------
# Local AI / scratch
# ------------------------------------------------------------
.claude/
memory/
.ebs_setup_scratch/

# ------------------------------------------------------------
# Temp files
# ------------------------------------------------------------
tmp/
*.tmp
*.bak
*.bak.*
